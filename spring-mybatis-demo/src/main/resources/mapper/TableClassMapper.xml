<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.TableClassMapper">

    <select id="selectByIdAndName" resultType="com.example.demo.model.TableClass">
        SELECT id, name, class AS className
        FROM table_class
        WHERE id = #{id} AND name = #{name}
    </select>

</mapper>
